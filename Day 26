class Solution:
    def generate(self, numRows: int) -> List[List[int]]:
        #base case
        res = [[1]]

        #from row 1 to numRows - 1
        for i in range(1, numRows):
            #row just built
            prev_row = res[-1]

            #start new row with 1
            new_row = [1]

            #calc mid element
            for j in range(1,i):
                new_row.append(prev_row[j-1] + prev_row[j])

            #end row with 1
            new_row.append(1)

            res.append(new_row)

        return res
        
